---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site.config';
import { serviceDetails } from '../roofing-content';

export function getStaticPaths() {
  return serviceDetails.map(service => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const serviceName = service.title.replace(' in Lexington, KY', '').toLowerCase();
const serviceUrl = `${SITE.url}/${service.slug}`;
const pageDescription = service.title.includes('Lexington')
  ? `${service.description} Call ${SITE.phoneDisplay} for roofing help.`
  : `${service.title} in Lexington, KY. ${service.description} Call ${SITE.phoneDisplay} for roofing help.`;
const whenToCallLead = service.bullets?.length
  ? `Call when ${service.bullets[0].toLowerCase()} matches what you are seeing. Also mention ${service.bullets.slice(1, 3).map(item => item.toLowerCase()).join(' or ')} so the first conversation starts with the right roof details.`
  : `Call when ${serviceName} is the closest match for the roof problem you are trying to solve.`;
const whenToCallSafety = `Do not climb for ${serviceName}; use ground photos and indoor clues instead. Focus on ${service.bullets?.slice(-2).map(item => item.toLowerCase()).join(' and ') ?? 'the safest visible details'} before the call.`;
const visitIntro = service.bullets?.length
  ? `For ${serviceName}, the visit starts with ${service.bullets[0].toLowerCase()} and then checks the roof details most likely to create that problem.`
  : `The visit starts with the roof symptom and then checks the details most likely to create it.`;
const visitSteps = [
  {
    title: `Share ${service.bullets?.[0] ?? service.schemaServiceType ?? service.title}`,
    body: `Add timing, room location, recent weather, and safe photos if those details clarify ${serviceName}.`,
  },
  {
    title: `Check ${service.bullets?.[1] ?? 'roof details'}`,
    body: `${service.bullets?.slice(2, 5).join('. ') ?? 'Visible wear. Flashing. Drainage.'}. These clues shape the roof review.`,
  },
  {
    title: `Plan around ${service.schemaServiceType ?? service.title}`,
    body: `Repair path: ${service.bullets?.[0] ?? service.title}. Protection path: ${service.bullets?.[1] ?? serviceName}. Planning path: ${service.bullets?.[2] ?? 'roof condition'}.`,
  },
];
const localDetailCopy = `For ${serviceName}: ${service.bullets?.[0] ?? 'visible roof symptoms'}. Lexington clue: ${service.bullets?.[1] ?? 'flashing and drainage'}. Roof detail: ${service.bullets?.[2] ?? 'vents and valleys'}. Ask about ${service.bullets?.[3] ?? 'roof age and access'}.`;
const localNeighborhoodCopy = `Neighborhood context for ${service.bullets?.[0]?.toLowerCase() ?? serviceName}: Chevy Chase, Kenwick, Hamburg, Beaumont, Masterson Station, and Tates Creek can differ by roof age, tree cover, access, and drainage pattern.`;
const costCopy = `Cost clue for ${service.bullets?.[0]?.toLowerCase() ?? serviceName}: height, pitch, and access. Cost clue for ${service.bullets?.[1]?.toLowerCase() ?? serviceName}: shingle match, decking, flashing, and ventilation.`;
const trustCopy = `For ${service.bullets?.[0]?.toLowerCase() ?? serviceName}, confirm insurance. For ${service.bullets?.[1]?.toLowerCase() ?? serviceName}, confirm permit expectations when scope requires it and get the written repair or replacement scope.`;
const serviceDetailCopy = `${service.title} calls should include plain details such as ${service.bullets?.map(item => item.toLowerCase()).join(', ') ?? serviceName}. Clear symptom language helps separate repairable roof details from broader roof planning.`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url + '/' },
    { '@type': 'ListItem', position: 2, name: service.title, item: serviceUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${serviceUrl}#service`,
  name: service.title,
  serviceType: service.schemaServiceType ?? service.title,
  description: service.description,
  url: serviceUrl,
  image: `${SITE.url}${service.image}`,
  provider: { '@id': `${SITE.url}#business` },
  areaServed: [
    { '@type': 'City', name: 'Lexington', containedInPlace: { '@type': 'State', name: 'Kentucky' } },
    { '@type': 'AdministrativeArea', name: 'Central Kentucky' },
  ],
  audience: {
    '@type': 'Audience',
    audienceType: 'Homeowners needing roofing help',
  },
  potentialAction: {
    '@type': 'ContactAction',
    name: `Call about ${serviceName}`,
    target: SITE.phoneHref,
  },
  mainEntityOfPage: serviceUrl,
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${serviceUrl}#next-steps`,
  name: `What to do before calling for ${serviceName}`,
  description: `Safe first steps before scheduling ${serviceName} in Lexington, KY.`,
  step: (service.steps ?? []).map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: `Step ${index + 1}`,
    text: step,
  })),
};
---
<BaseLayout
  title={service.title}
  description={pageDescription}
  schema={[serviceSchema, howToSchema, faqSchema, breadcrumb]}
  ogImage={service.image}
>
  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> <span aria-hidden="true">›</span> {service.title}
  </nav>

  <section class="hero service-hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">{service.eyebrow}</span>
        <h1>{service.title}</h1>
        <p class="hero-sub">{service.description}</p>
        <div class="hero-badges">
          <span class="badge badge--light">{service.schemaServiceType ?? service.title}</span>
          <span class="badge badge--light">Lexington roof detail review</span>
          <span class="badge badge--light">Practical next-step guidance</span>
        </div>
        <div class="hero-cta">
          <a href={SITE.phoneHref} class="btn btn-primary btn-large" data-cta="service-hero">Call {SITE.phoneDisplay}</a>
          <a href="/contact" class="btn btn-secondary btn-large" data-cta="service-contact">Request Estimate</a>
        </div>
      </div>
      <img src={service.image} alt={service.alt} width="1536" height="1024" loading="eager" fetchpriority="high" decoding="async" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <article class="card">
          <h2>Roofing Issues This Covers</h2>
          <ul class="list-clean">
            {service.bullets.map(item => <li>{item}</li>)}
          </ul>
        </article>
        <article class="card">
          <h2>When to Call</h2>
          <p>{whenToCallLead}</p>
          <p>{whenToCallSafety}</p>
          <a href={SITE.phoneHref} class="btn btn-primary" data-cta="when-call">Call {SITE.phoneDisplay}</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>What Happens During the Visit</h2>
        <p>{visitIntro}</p>
      </div>
      <div class="grid grid-3">
        {visitSteps.map((step, index) => (
          <article class="card"><h3>{index + 1}. {step.title}</h3><p>{step.body}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card">
        <h2>Local Roof Details That Matter</h2>
        <p>{localDetailCopy}</p>
        <p>{localNeighborhoodCopy}</p>
      </article>
      <article class="card">
        <h2>What Affects Cost</h2>
        <p>{costCopy}</p>
        <p>{trustCopy}</p>
        <p>{serviceDetailCopy}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Related Roofing Help in Lexington</h2>
        <p>These pages connect the main roofing service to the problem a homeowner is actually searching for.</p>
      </div>
      <div class="grid grid-3">
        {service.relatedLinks.map(link => (
          <article class="card">
            <h3><a href={link.href}>{link.label}</a></h3>
            <p>{link.description ?? `Use this page when ${link.label.toLowerCase()} is closer to the problem you are trying to solve today.`}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head"><h2>Frequently Asked Questions</h2></div>
      {service.faqs.map(f => (
        <details class="faq">
          <summary>{f.q}</summary>
          <div class="faq-body">{f.a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <h2>Talk through your roofing concern today.</h2>
      <p>Call for {serviceName} in Lexington and nearby Central Kentucky communities.</p>
      <div class="hero-cta center">
        <a href={SITE.phoneHref} class="btn btn-primary btn-large" data-cta="service-final">Call {SITE.phoneDisplay}</a>
        <a href="/contact" class="btn btn-secondary btn-large" data-cta="service-final-contact">Request Roofing Help</a>
      </div>
    </div>
  </section>
</BaseLayout>
